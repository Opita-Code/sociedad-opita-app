{
  "name": "sociedad-opita-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Sociedad Opita API — backend del monumento cultural vivo. SST v3 + TypeScript + @opita/ocais.",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "sst dev",
    "deploy": "sst deploy",
    "deploy:prod": "sst deploy --stage prod",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts --max-warnings 999",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "pre-commit": "lint-staged",
    "prepare": "simple-git-hooks || true"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0",
    "@opita/ocais": "github:Opita-Code/ocais#v2.0.0",
    "dotenv": "^17.4.2",
    "hono": "^4.6.0",
    "sst": "^3.14.2"
  },
  "devDependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "fast-check": "^4.8.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "simple-git-hooks": "^2.9.0",
    "tsx": "4.22.4",
    "typescript": "^5.7.0",
    "vitest": "^3.2.1"
  }
}
