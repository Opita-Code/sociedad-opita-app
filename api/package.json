{
  "name": "sociedad-opita-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Sociedad Opita API — backend del monumento cultural vivo. SST v3 + TypeScript + @opita/ocais.",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "sst dev",
    "deploy": "sst deploy",
    "deploy:prod": "sst deploy --stage prod",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opita/ocais": "*",
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0",
    "dotenv": "^17.4.2",
    "hono": "^4.6.0",
    "sst": "^3.14.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.1"
  }
}
