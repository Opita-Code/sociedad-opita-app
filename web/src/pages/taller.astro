---
import Layout from "../layouts/Layout.astro";

/**
 * Sociedad Opita — Taller
 *
 * La dimensión académica: el detrás de escena del monumento.
 * Aquí viven el paper, los datos, los descargables, y la memoria
 * completa — incluida la Masacre del Puente de los Decapitados (1950).
 *
 * Decisiones del operador incorporadas (S3):
 * 1. Masacre del Puente de los Decapitados (1950) — sección dedicada
 * 2. ES only
 * 3. Personas híbrido: 10 arquetipos actuales + 31 pendientes con consentimiento
 * 4. Himno de Tello: Delia Camacho & Álvaro Velásquez
 * 5. Banano 91% en pueblo-en-números (también en home)
 * 6. Mobile-first, <50KB, sin JS framework, sin tracking
 * 7. 8+ reportes Artesanías de Colombia descargables
 * 8. Style lock B/N (Benjamín de la Calle + Nereo López + Pedro Nel Gómez)
 * 9. WhatsApp bridge
 * 10. 204 papers BibTeX descargables con filtros
 */

const WHATSAPP_URL = "https://wa.me/573126126085";

// 10 diálogos validados (sincrónicos con api/src/personas.ts)
// imagen_tipo: 'ai' = AI-generated declarado honestamente, 'placeholder' = SVG 1-letter, null = sin imagen
const personas = [
  {
    nombre: "Don Rosalío",
    rol: "ganadero propietario",
    arquetipo: "ganadero tradicional",
    muletillas: "asina es la cosa · le digo yo · ni muerto",
    cita: '"Asina es la cosa, mijo: la tierra no se negocia, se hereda."',
    capa: "Lomnitz A · Dunbar 25",
    imagen: null,
    imagen_tipo: null,
  },
  {
    nombre: "Doña Rosa Elvira",
    rol: "tendera fiadera",
    arquetipo: "tendero de pueblo",
    muletillas: "mire ve · le cuento · eso sí es verriondo",
    cita: '"Mire ve, le cuento: en esta tienda se sabe quién vive, quién muere y quién fía."',
    capa: "Lomnitz B · Dunbar 30 (super-spreader 0,55)",
    imagen: "/persona-dona-rosa.svg",
    imagen_tipo: "placeholder",
  },
  {
    nombre: "Padre Cecilio",
    rol: "párroco",
    arquetipo: "sacerdote rural",
    muletillas: "Dios es el que sabe · mijo · rezaremos por ello",
    cita: '"Dios es el que sabe, mijo. Aquí rezamos por vivos y por difuntos por igual."',
    capa: "Lomnitz A · Dunbar 30",
    imagen: "/persona-padre-cecilio.svg",
    imagen_tipo: "placeholder",
  },
  {
    nombre: "Doña Prudencia",
    rol: "viuda anfitriona",
    arquetipo: "viuda anfitriona",
    muletillas: "Dios mediante · Ave María Purísima · pues sí mijita",
    cita: '"Pues sí mijita, Dios mediante, mañana le llevo un tintico a Doña Rosa."',
    capa: "Lomnitz A · Dunbar 28",
    imagen: "/persona-dona-prudencia.jpg",
    imagen_tipo: "ai",
  },
  {
    nombre: "Jhon Eliécer",
    rol: "jornalero",
    arquetipo: "trabajador rural",
    muletillas: "pues mira ve · le cuento · eso sí es verriondo",
    cita: '"Pues mira ve, eso sí es verriondo: trabajar la tierra ajena toda la vida."',
    capa: "Lomnitz A · Dunbar 18",
    imagen: "/persona-jhon-eliecer.svg",
    imagen_tipo: "placeholder",
  },
  {
    nombre: "Don Octavio",
    rol: "médico tradicional",
    arquetipo: "médico tradicional",
    muletillas: "eso no es así · fíjese pues · le digo por su bien",
    cita: '"Fíjese pues, eso no es así: una agüita de boldo con limoncillo le compone el mal."',
    capa: "Lomnitz A · Dunbar 26",
    imagen: "/persona-don-octavio.svg",
    imagen_tipo: "placeholder",
  },
  {
    nombre: "Don Emigdio",
    rol: "agricultor caficultor",
    arquetipo: "trabajador rural",
    muletillas: "si Dios quiere · pues sí · hay que trabajar",
    cita: '"Si Dios quiere, este año la cosecha se deja ver."',
    capa: "Lomnitz A · Dunbar 20",
    imagen: "/persona-don-emigdio.svg",
    imagen_tipo: "placeholder",
  },
  {
    nombre: "Don Eliécer",
    rol: "finquero patrón",
    arquetipo: "ganadero tradicional",
    muletillas: "le digo yo · eso no se hace · hágale pues",
    cita: '"Hágale pues, mijo, eso no se hace: la finca pide respeto."',
    capa: "Lomnitz A · Dunbar 22",
    imagen: "/persona-don-eliecer.jpg",
    imagen_tipo: "ai",
  },
  {
    nombre: "Jhon Jairo",
    rol: "sacristán peregrino",
    arquetipo: "artesano independiente",
    muletillas: "con Dios · Ave María · Dios mediante",
    cita: '"Dios mediante, hoy la iglesia está de fiesta."',
    capa: "Lomnitz A · Dunbar 24",
    imagen: "/persona-jhon-jairo.svg",
    imagen_tipo: "placeholder",
  },
  {
    nombre: "Jhon Fredy",
    rol: "joven retornado",
    arquetipo: "joven migrante",
    muletillas: "parce · nojoda · esa vaina",
    cita: '"Parce, nojoda: volví porque Bogotá no era pa mí."',
    capa: "Lomnitz B · Dunbar 22",
    imagen: "/persona-jhon-fredy.svg",
    imagen_tipo: "placeholder",
  },
];

// Reportes de Artesanías de Colombia (nombres tomados del FINAL-RECON-REPORT.md §5
// y del papers-tello.bib verificado por sub-agente C).
// Los 5 primeros tienen URL verificada en repositorio.artesaniasdecolombia.com.co.
// Los 3 restantes son reportes adicionales documentados en el recon sin URL capturada.
const artesanias = [
  {
    titulo: "Memoria de tejidos y cordones, Tello Huila",
    anio: 1995,
    archivo: "1995-memoria-tejidos-tello.pdf",
    verificada: false,
  },
  {
    titulo: "Taller de cestería en guadua, Tello",
    anio: 1997,
    archivo: "1997-taller-cesteria.pdf",
    verificada: true,
    url_real:
      "https://repositorio.artesaniasdecolombia.com.co/bitstream/001/10588/1/INST-D%201997.%20196.pdf",
  },
  {
    titulo: "Taller de pintura artesanal, Tello",
    anio: 1997,
    archivo: "1997-taller-pintura.pdf",
    verificada: false,
  },
  {
    titulo: "Mejoramiento del producto artesanal en guadua y bejuco en Tello, Huila",
    anio: 2006,
    archivo: "2006-guadua-bejuco.pdf",
    verificada: true,
    url_real:
      "https://repositorio.artesaniasdecolombia.com.co/bitstream/001/637/8/INST-D%202006.%20140.pdf",
  },
  {
    titulo: "Mejoramiento tecnológico de herramientas para tiras de guadua, Tello",
    anio: 2006,
    archivo: "2006-herramientas-tiras-guadua.pdf",
    verificada: false,
  },
  {
    titulo: "Diagnóstico productivo de la cestería en guadua",
    anio: 2010,
    archivo: "2010-diagnostico-cesteria-guadua.pdf",
    verificada: false,
  },
  {
    titulo: "Caracterización de oficios artesanales del Huila",
    anio: 2014,
    archivo: "2014-caracterizacion-oficios-huila.pdf",
    verificada: false,
  },
  {
    titulo: "Mujeres artesanas y memoria cultural tellense",
    anio: 2022,
    archivo: "2022-mujeres-artesanas-tellenses.pdf",
    verificada: false,
  },
];

const bibtex = `@misc{opita2026tello,
  title  = {A Living Digital Monument of a Colombian Town: Tello, Huila as Case Study in Sociolinguistic Preservation},
  author = {Urrutia Salcedo, Juan Nicolás},
  year   = {2026},
  note   = {CC-BY-4.0},
  url    = {https://sociedad.opitacode.com/taller}
}`;

const secciones = [
  { id: "masacre-1950", titulo: "La Masacre del Puente de los Decapitados (1950)" },
  { id: "paper-bibtex", titulo: "Paper + BibTeX" },
  { id: "dialogos-validados", titulo: "10 diálogos validados" },
  { id: "ground-truth", titulo: "Ground truth ZIP descarga" },
  { id: "artesanias", titulo: "Reportes de Artesanías de Colombia" },
  { id: "papers-bib", titulo: "204 papers académicos (BibTeX)" },
  { id: "methodology", titulo: "Methodology" },
  { id: "limitations", titulo: "Limitations" },
  { id: "ethics", titulo: "Research ethics" },
  { id: "replicar", titulo: "Cómo replicar el estudio" },
];
---

<Layout
  title="Taller — Sociedad Opita"
  description="El detrás de escena académico del monumento digital vivo: paper, 10 diálogos validados, BibTeX, reportes de Artesanías de Colombia, 204 papers académicos y la memoria de la Masacre del Puente de los Decapitados (1950)."
  ogType="article"
>
  <main class="max-w-5xl mx-auto px-6 py-16 md:py-24">
    <!-- Hero -->
    <header class="text-center mb-16">
      <p class="text-sm uppercase tracking-widest text-opita-tierra mb-4">Dimensión Taller</p>
      <h1 class="text-4xl md:text-6xl font-serif text-opita-cafe mb-6 leading-tight">
        El detrás de escena académico
      </h1>
      <p class="text-lg md:text-xl text-opita-cafe/80 max-w-3xl mx-auto leading-relaxed">
        El paper, los datos, los 10 diálogos validados, los reportes, los papers, la memoria.
        Sociedad Opita no es solo un producto: es un proceso de investigación que aquí se documenta
        completo.
      </p>
    </header>

    <!-- Tabla de contenidos -->
    <nav
      class="bg-opita-cafe text-opita-arena rounded-lg p-6 md:p-8 mb-16 md:sticky md:top-4 md:z-10"
      aria-label="Tabla de contenidos"
    >
      <p class="text-sm uppercase tracking-widest text-opita-arena/70 mb-4">Tabla de contenidos</p>
      <ol class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-2">
        {
          secciones.map((s, i) => (
            <li class="text-sm">
              <a href={`#${s.id}`} class="hover:text-opita-plaza transition-colors">
                <span class="text-opita-arena/50 mr-2">{String(i + 1).padStart(2, "0")}.</span>
                {s.titulo}
              </a>
            </li>
          ))
        }
      </ol>
    </nav>

    <!-- Sección 1: Masacre del Puente de los Decapitados (1950) -->
    <section id="masacre-1950" class="mb-20 scroll-mt-20">
      <p class="text-sm uppercase tracking-widest text-opita-tierra mb-3">
        01 · Memoria del pueblo
      </p>
      <h2 class="text-3xl md:text-4xl font-serif text-opita-cafe mb-6">
        La Masacre del Puente de los Decapitados (1950)
      </h2>

      <p class="text-lg text-opita-cafe/80 leading-relaxed mb-4">
        La memoria que también es Tello. En 1950, durante La Violencia bipartidista, más de 500
        hombres liberales fueron ejecutados por fuerzas conservadoras en el puente y la carretera de
        entrada al casco urbano. Sus cuerpos fueron exhibidos allí.
      </p>
      <p class="text-lg text-opita-cafe/80 leading-relaxed mb-4">
        Tello era una <strong>"plaza roja"</strong> en el Huila conservador: uno de los pueblos donde
        la lucha entre liberales y conservadores dejó las huellas más profundas. La <em
          >Quemazón de San Andrés</em
        >, vereda del municipio, fue incendiada durante el mismo período.
      </p>
      <p class="text-lg text-opita-cafe/80 leading-relaxed mb-6">
        Esta sección existe porque un monumento cultural que ignora 1950 no es un monumento — es
        propaganda. Pero el tono aquí es deliberado: dignidad, no morbo. Honramos a los muertos sin
        reducir la memoria a trauma.
      </p>

      <blockquote
        class="border-l-4 border-opita-tierra bg-opita-arena/40 rounded-r-lg p-6 md:p-8 mb-6"
      >
        <p class="text-xl md:text-2xl font-serif text-opita-cafe italic leading-snug">
          "El monumento a Tello no es solo el que sobrevive — es también el que recuerda."
        </p>
      </blockquote>

      <h3 class="text-xl font-serif text-opita-cafe mb-3">Fuentes consultadas</h3>
      <ul class="list-disc list-inside text-sm text-opita-cafe/80 space-y-1 mb-6">
        <li>Wikipedia EN: "Tello, Huila" (sección La Violencia).</li>
        <li>Wikipedia ES: "Tello (Huila)" (historia contemporánea).</li>
        <li>
          Caicedo, Armando (compilador). <em>La Carnicería: plazas rojas del Huila</em>. 2010.
          Compilación periodística de los hechos violentos bipartidistas en el departamento.
        </li>
        <li>
          Trabajo de campo cualitativo en Tello (2024–2025): entrevistas con habitantes que
          transmiten la memoria oral.
        </li>
      </ul>

      <h3 class="text-xl font-serif text-opita-cafe mb-3">Decisión metodológica</h3>
      <p class="text-base text-opita-cafe/80 leading-relaxed">
        Esta masacre <strong>no</strong> se replica como contenido interactivo, no se usa como mecánica
        emocional, y no se cuantifica. Es contexto fundacional: explica por qué un pueblo de 12.908 habitantes
        decide hoy preservar su voz antes de que se apague.
      </p>
    </section>

    <!-- Sección 2: Paper + BibTeX -->
    <section id="paper-bibtex" class="mb-20 scroll-mt-20">
      <p class="text-sm uppercase tracking-widest text-opita-tierra mb-3">02 · Paper académico</p>
      <h2 class="text-3xl md:text-4xl font-serif text-opita-cafe mb-6">Paper + BibTeX</h2>

      <p class="text-base text-opita-cafe/80 leading-relaxed mb-6">
        El paper completo describe la metodología, los hallazgos y las limitaciones. Descarga el PDF
        y la cita BibTeX abajo.
      </p>

      <div class="bg-white border-2 border-opita-magdalena rounded-lg p-6 md:p-8 mb-6">
        <h3 class="text-xl font-serif text-opita-magdalena mb-3">
          A Living Digital Monument of a Colombian Town
        </h3>
        <p class="text-sm text-opita-cafe/80 mb-4">
          Caso de estudio: Tello, Huila. Preservación sociolingüística con IA, validados por
          hablante nativo del dialecto opita.
        </p>
        <a
          href="/downloads/paper-opita-2026.pdf"
          class="inline-block bg-opita-magdalena text-opita-arena px-6 py-3 rounded-lg text-sm font-serif hover:bg-opita-tierra transition-colors"
        >
          Descargar paper (PDF)
        </a>
        <p class="text-xs text-opita-cafe/60 mt-3 italic">
          Pendiente de subir. Licencia CC-BY-4.0.
        </p>
      </div>

      <h3 class="text-xl font-serif text-opita-cafe mb-3">Cita BibTeX</h3>
      <pre
        class="bg-opita-cafe text-opita-arena rounded-lg p-6 overflow-x-auto text-sm"><code>{bibtex}</code></pre>
    </section>

    <!-- Sección 3: 10 diálogos validados -->
    <section id="dialogos-validados" class="mb-20 scroll-mt-20">
      <p class="text-sm uppercase tracking-widest text-opita-tierra mb-3">03 · Voces del pueblo</p>
      <h2 class="text-3xl md:text-4xl font-serif text-opita-cafe mb-6">
        10 diálogos validados por hablante nativo
      </h2>

      <p class="text-base text-opita-cafe/80 leading-relaxed mb-8">
        Estas son las 10 personas de las 41 documentadas que tienen su arquetipo, sus muletillas, su
        perfil Big Five + Lomnitz + Dunbar validados por un hablante nativo del opita. Las 31
        restantes se agregan progresivamente con consentimiento explícito.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {
          personas.map((p) => (
            <article class="bg-white border-l-4 border-opita-plaza rounded-r-lg p-5 md:p-6 shadow-sm">
              <div class="flex items-start gap-4 mb-3">
                {p.imagen && p.imagen_tipo === "ai" && (
                  <figure class="flex-shrink-0">
                    <img
                      src={p.imagen}
                      alt={`Retrato AI de ${p.nombre} — generado por IA, no es fotografía documental`}
                      width="56"
                      height="56"
                      loading="lazy"
                      class="w-14 h-14 rounded-full object-cover border border-opita-tierra/40"
                    />
                  </figure>
                )}
                {p.imagen && p.imagen_tipo === "placeholder" && (
                  <figure class="flex-shrink-0">
                    <img
                      src={p.imagen}
                      alt={`Marcador tipográfico para ${p.nombre} — sin retrato disponible`}
                      width="56"
                      height="56"
                      loading="lazy"
                      class="w-14 h-14 rounded-full border border-opita-tierra/40"
                    />
                  </figure>
                )}
                {!p.imagen && (
                  <div class="flex-shrink-0 w-14 h-14 rounded-full bg-opita-tierra text-opita-arena flex items-center justify-center font-serif text-xl">
                    {p.nombre.replace(/^(Don|Doña|Padre) /, "").charAt(0)}
                  </div>
                )}
                <div>
                  <h3 class="text-lg font-serif text-opita-cafe leading-tight">{p.nombre}</h3>
                  <p class="text-xs uppercase tracking-wider text-opita-tierra">{p.rol}</p>
                  {p.imagen_tipo === "ai" && (
                    <p class="text-[10px] uppercase tracking-wider text-opita-verriondo mt-1">
                      Retrato AI — B/N documental inspirado en Benjamín de la Calle y Nereo López;
                      no fotográfico documental
                    </p>
                  )}
                  {p.imagen_tipo === "placeholder" && (
                    <p class="text-[10px] uppercase tracking-wider text-opita-tierra/70 mt-1">
                      Sin retrato — placeholder tipográfico
                    </p>
                  )}
                </div>
              </div>
              <p class="text-sm text-opita-cafe/70 italic mb-2">
                <strong>Muletillas:</strong> {p.muletillas}
              </p>
              <blockquote class="border-l-2 border-opita-hueso pl-3 my-3">
                <p class="text-sm text-opita-cafe/90 font-serif italic">{p.cita}</p>
              </blockquote>
              <p class="text-xs text-opita-cafe/60">
                {p.capa} · arquetipo: {p.arquetipo}
              </p>
            </article>
          ))
        }
      </div>
      <p class="text-xs text-opita-cafe/60 mt-6">
        Atribución completa de las imágenes de personas: 2 retratos AI declarados honestamente (Doña
        Prudencia, Don Eliécer); 7 marcadores tipográficos como placeholders honestos (Doña Rosa,
        Padre Cecilio, Jhon Eliécer, Don Octavio, Don Emigdio, Jhon Jairo, Jhon Fredy). Don Rosalío
        aún no tiene marcador gráfico. Ver <a
          href="/VISUAL-HONESTY.md"
          class="underline hover:text-opita-tierra">honestidad visual</a
        >.
      </p>
    </section>

    <!-- Sección 4: Ground truth ZIP -->
    <section id="ground-truth" class="mb-20 scroll-mt-20">
      <p class="text-sm uppercase tracking-widest text-opita-tierra mb-3">04 · Datos crudos</p>
      <h2 class="text-3xl md:text-4xl font-serif text-opita-cafe mb-6">
        Ground truth ZIP descarga
      </h2>

      <p class="text-base text-opita-cafe/80 leading-relaxed mb-6">
        El ZIP completo incluye: 41 perfiles psicométricos (CSV), las 10 transcripciones validadas
        (TXT), los 249 ways de OSM (GeoJSON), el CSV del DANE CNPV 2018 + proyección 2025, y un
        archivo LEÉME con el diccionario de datos. Licencia CC-BY-4.0.
      </p>

      <a
        href="/downloads/ground-truth.zip"
        class="inline-block bg-opita-tierra text-opita-arena px-6 py-3 rounded-lg text-sm font-serif hover:bg-opita-verriondo transition-colors"
      >
        Descargar ground-truth.zip
      </a>
      <p class="text-xs text-opita-cafe/60 mt-3 italic">
        Pendiente de subir. Se publica al cierre del S3.
      </p>
    </section>

    <!-- Sección 5: Reportes de Artesanías de Colombia -->
    <section id="artesanias" class="mb-20 scroll-mt-20">
      <p class="text-sm uppercase tracking-widest text-opita-tierra mb-3">
        05 · Patrimonio artesanal
      </p>
      <h2 class="text-3xl md:text-4xl font-serif text-opita-cafe mb-6">
        8 reportes de Artesanías de Colombia
      </h2>

      <p class="text-base text-opita-cafe/80 leading-relaxed mb-6">
        Artesanías de Colombia documentó la cadena productiva artesanal de Tello en al menos 8
        reportes entre 1995 y 2022. Cestería en guadua, pintura, tejidos, oficios. Son la base
        histórica del patrimonio material del municipio. De los 8, 2 tienen URL verificada en el
        repositorio público y 6 están pendientes de descarga local con atribución completa.
      </p>

      <ul class="space-y-3">
        {
          artesanias.map((a) => (
            <li class="bg-white border border-opita-hueso rounded-lg p-4 md:p-5 flex flex-col md:flex-row md:items-center md:justify-between gap-3">
              <div class="flex-1">
                <h3 class="text-base font-serif text-opita-cafe leading-tight">
                  {a.titulo}
                  {a.verificada && (
                    <span class="ml-2 text-xs uppercase tracking-wider text-opita-plaza align-middle">
                      · URL verificada
                    </span>
                  )}
                </h3>
                <p class="text-xs text-opita-cafe/60 mt-1">Artesanías de Colombia · {a.anio}</p>
              </div>
              <a
                href={`/downloads/artesanias/${a.archivo}`}
                class="text-sm text-opita-tierra underline hover:text-opita-verriondo whitespace-nowrap"
              >
                Descargar PDF →
              </a>
            </li>
          ))
        }
      </ul>
      <p class="text-xs text-opita-cafe/60 mt-6 italic">
        Fuente original: <a
          href="https://repositorio.artesaniasdecolombia.com.co"
          class="underline hover:text-opita-tierra">repositorio.artesaniasdecolombia.com.co</a
        >. Las dos entradas marcadas como "URL verificada" tienen descarga directa desde el
        repositorio público. Las seis restantes requieren descarga local con atribución completa del
        autor y fotógrafo. Licencia original de cada reporte.
      </p>
    </section>

    <!-- Sección 6: papers BibTeX -->
    <section id="papers-bib" class="mb-20 scroll-mt-20">
      <p class="text-sm uppercase tracking-widest text-opita-tierra mb-3">
        06 · Revisión bibliográfica
      </p>
      <h2 class="text-3xl md:text-4xl font-serif text-opita-cafe mb-6">
        Corpus académico verificado (BibTeX)
      </h2>

      <p class="text-base text-opita-cafe/80 leading-relaxed mb-6">
        Revisión de la literatura académica sobre Tello, el Huila, La Violencia bipartidista, el
        dialecto opita y temas adyacentes. El reporte de reconocimiento inicial mencionaba ~204
        resultados en Google Scholar; al verificar entrada por entrada se documentaron 9 papers con
        metadata confirmada (6 con URL de descarga directa, 3 pendientes de URL en Artesanías de
        Colombia). Las entradas no verificadas se omitieron deliberadamente antes que inflar el
        corpus.
      </p>

