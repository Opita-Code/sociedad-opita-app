---
import Layout from '../layouts/Layout.astro';

/**
 * Sociedad Opita — Réplica
 *
 * La dimensión para extender el monumento a otros municipios del Huila
 * (y eventualmente del país). NO es self-service: cada réplica es curada
 * con conversaciones reales con personas del municipio destino.
 *
 * Decisiones del operador incorporadas (S3):
 * - Curated, not self-service (3-4 pasos con humano en el loop)
 * - 3 municipios piloto: Garzón (en conversación), Pitalito (Q4 2026), La Plata (Q1 2027)
 * - WhatsApp bridge como canal principal (decisión 9)
 * - Mailto simple para datos estructurados (decisión 9)
 * - ES only, mobile-first, paleta opita
 */

const WHATSAPP_URL = 'https://wa.me/573126126085';
const REPLICA_EMAIL = 'replicas@opitacode.com';

const pasos = [
  {
    numero: '01',
    titulo: 'Nos escribes',
    descripcion: 'Por WhatsApp o por correo. Nos cuentas qué pueblo, por qué, y qué te preocupa que se pierda. Sin formulario de 20 campos.',
  },
  {
    numero: '02',
    titulo: 'Conversamos con 2-3 personas del municipio',
    descripcion: 'Viajamos o conectamos por videollamada. Hablamos con el tendero, la maestra, el cura, el viejo del parque. Lo que ellos recuerden del pueblo, en sus palabras.',
  },
  {
    numero: '03',
    titulo: 'Documentamos sus muletillas, su plaza, su tinto',
    descripcion: 'Grabamos con consentimiento. Transcribimos en opita (o en el dialecto local). Georreferenciamos los edificios del casco urbano. Validamos con un nativo.',
  },
  {
    numero: '04',
    titulo: 'Provisionamos en menos de 10 minutos',
    descripcion: 'Subdominio propio (tupueblo.opitacode.com), datos tuyos, código tuyo. Capacitamos a 2 personas del municipio para mantenerlo. Tiempo total: ~6 meses.',
  },
];

const pilotos = [
  {
    municipio: 'Garzón',
    status: 'en conversación',
    status_color: 'plaza',
    descripcion: 'La Universidad Surcolombiana sede Garzón ya se acercó. Estamos hablando con la facultad de Ciencias Sociales y con la personería. Próximo paso: visita de campo en julio 2026.',
    personas: '0 documentadas',
    imagen: '/tile-replica.jpg',
    imagen_alt: 'Paisaje del Huila — referencia de la familia visual andina',
    imagen_credito: 'Wikimedia Commons · CC-BY-SA-4.0',
  },
  {
    municipio: 'Pitalito',
    status: 'Q4 2026',
    status_color: 'magdalena',
    descripcion: 'La alcaldía de Pitalito mostró interés por el Laboratorio de Paz del Macizo colombiano. Pitalito es la segunda ciudad del Huila — el reto es preservar el dialecto laboyano sin reducirlo a folklore.',
    personas: '0 documentadas',
    imagen: '/tile-puente.jpg',
    imagen_alt: 'Río Magdalena — conexión entre municipios del Huila',
    imagen_credito: 'Wikimedia Commons · CC-BY-SA-4.0',
  },
  {
    municipio: 'La Plata',
    status: 'Q1 2027',
    status_color: 'cafe',
    descripcion: 'Por solicitud de la Personería de La Plata. Cuenca del río Páez, zona de reconstrucción post-nevado del Huila (1994) y post-conflicto. La memoria aquí es otra capa.',
    personas: '0 documentadas',
    imagen: '/tile-ventana.jpg',
    imagen_alt: 'Biblioteca departamental — referencia arquitectónica civil',
    imagen_credito: 'Wikimedia Commons · CC-BY-SA-4.0',
  },
];
---

<Layout
  title="Réplica — Sociedad Opita"
  description="Extiende el monumento digital a otros municipios del Huila. Proceso curado, 6 meses por pueblo, código y datos abiertos."
  ogType="website"
>
  <main class="max-w-5xl mx-auto px-6 py-16 md:py-24">
    <!-- Plaza similar: imagen real con declaración honesta -->
    <figure class="mb-10">
      <img
        src="/plaza-similar-tello.jpg"
        alt="Plaza con adornos navideños, similar en escala a la plaza de un pueblo andino del Huila"
        width="1280"
        height="720"
        loading="eager"
        class="w-full h-auto rounded-lg shadow-md"
      />
      <figcaption class="text-xs text-opita-tierra mt-3 italic text-center">
        Foto: <em>Panorámica de los adornos navideños</em> · Wikimedia Commons · CC-BY-SA-4.0.
        Referencia visual de plaza pública del Huila, similar en escala a la Plaza Bolívar de Tello. Tello no tiene aún archivo fotográfico público abierto en Commons; usamos pueblos del mismo terreno y misma familia arquitectónica como sustituto honesto (ver <a href="/VISUAL-HONESTY.md" class="underline hover:text-opita-verriondo">honestidad visual</a>).
      </figcaption>
    </figure>

    <!-- Hero -->
    <header class="text-center mb-16">
      <p class="text-sm uppercase tracking-widest text-opita-tierra mb-4">
        Dimensión Réplica
      </p>
      <h1 class="text-4xl md:text-6xl font-serif text-opita-cafe mb-6 leading-tight">
        Extiende el monumento a otro pueblo
      </h1>
      <p class="text-lg md:text-xl text-opita-cafe/80 max-w-3xl mx-auto leading-relaxed">
        Si tu pueblo merece ser preservado — sus voces, sus plazas, su forma
        de hablar — replica el simulador. No es un template que compras y
        despliegas. Es un proceso curado, con personas reales, que toma
        alrededor de 6 meses por municipio.
      </p>
    </header>

    <!-- Cómo funciona -->
    <section class="mb-20">
      <p class="text-sm uppercase tracking-widest text-opita-tierra mb-3">
        Cómo funciona
      </p>
      <h2 class="text-3xl md:text-4xl font-serif text-opita-cafe mb-10">
        Cuatro pasos. Con personas, no con SaaS.
      </h2>

      <ol class="space-y-8">
        {pasos.map((paso) => (
          <li class="bg-white border-l-4 border-opita-plaza rounded-r-lg p-6 md:p-8 shadow-sm">
            <div class="flex items-start gap-6">
              <span class="flex-shrink-0 text-3xl md:text-4xl font-serif text-opita-plaza">
                {paso.numero}
              </span>
              <div>
                <h3 class="text-xl md:text-2xl font-serif text-opita-cafe mb-2">
                  {paso.titulo}
                </h3>
                <p class="text-base text-opita-cafe/80 leading-relaxed">
                  {paso.descripcion}
                </p>
              </div>
            </div>
          </li>
        ))}
      </ol>
    </section>

    <!-- Municipios piloto -->
    <section class="mb-20">
      <p class="text-sm uppercase tracking-widest text-opita-tierra mb-3">
        Municipios piloto
      </p>
      <h2 class="text-3xl md:text-4xl font-serif text-opita-cafe mb-10">
        Tres municipios en el horizonte
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {pilotos.map((p) => (
          <article class={`bg-white border-2 border-opita-${p.status_color} rounded-lg overflow-hidden shadow-sm flex flex-col`}>
            <figure class="aspect-video overflow-hidden bg-opita-hueso/30">
              <img
                src={p.imagen}
                alt={p.imagen_alt}
                width="1280"
                height="720"
                loading="lazy"
                class="w-full h-full object-cover"
              />
            </figure>
            <div class="p-6 flex-1 flex flex-col">
              <h3 class="text-2xl font-serif text-opita-cafe mb-2">
                {p.municipio}
              </h3>
              <p class={`text-xs uppercase tracking-widest text-opita-${p.status_color} mb-4`}>
                {p.status}
              </p>
              <p class="text-sm text-opita-cafe/80 leading-relaxed mb-4 flex-1">
                {p.descripcion}
              </p>
              <p class="text-xs text-opita-cafe/60 italic mb-1">
                {p.personas}
              </p>
              <p class="text-[10px] text-opita-cafe/50 italic">
                {p.imagen_credito}
              </p>
            </div>
          </article>
        ))}
      </div>
      <p class="text-xs text-opita-cafe/60 mt-6 text-center">
        Imágenes de referencia visual: 62 fotos Wikimedia Huila-departamental
        disponibles en <a href="/VISUAL-HONESTY.md" class="underline hover:text-opita-tierra">honestidad visual</a>;
        pendiente atribución por municipio y por fotógrafo para uso en producción.
      </p>
    </section>

    <!-- Form simple -->
    <section class="mb-20">
      <p class="text-sm uppercase tracking-widest text-opita-tierra mb-3">
        O escríbenos
      </p>
      <h2 class="text-3xl md:text-4xl font-serif text-opita-cafe mb-6">
        Cuéntanos de tu pueblo
      </h2>
      <p class="text-base text-opita-cafe/80 mb-8 max-w-2xl">
        Si prefieres no usar WhatsApp, mándanos estos datos por correo.
        Respondemos en menos de 48 horas.
      </p>

      <form
        action={`mailto:${REPLICA_EMAIL}`}
        method="post"
        enctype="text/plain"
        class="bg-white border-2 border-opita-tierra rounded-lg p-6 md:p-8 space-y-5"
      >
        <div>
          <label for="nombre" class="block text-sm uppercase tracking-wider text-opita-tierra mb-2">
            Tu nombre
          </label>
          <input
            type="text"
            id="nombre"
            name="nombre"
            required
            class="w-full px-4 py-3 border border-opita-hueso rounded bg-opita-arena text-opita-cafe focus:outline-none focus:border-opita-tierra"
          />
        </div>

        <div>
          <label for="municipio" class="block text-sm uppercase tracking-wider text-opita-tierra mb-2">
            Municipio que quieres preservar
          </label>
          <input
            type="text"
            id="municipio"
            name="municipio"
            required
            class="w-full px-4 py-3 border border-opita-hueso rounded bg-opita-arena text-opita-cafe focus:outline-none focus:border-opita-tierra"
          />
        </div>

        <div>
          <label for="email" class="block text-sm uppercase tracking-wider text-opita-tierra mb-2">
            Tu correo electrónico
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-4 py-3 border border-opita-hueso rounded bg-opita-arena text-opita-cafe focus:outline-none focus:border-opita-tierra"
          />
        </div>

        <div>
          <label for="mensaje" class="block text-sm uppercase tracking-wider text-opita-tierra mb-2">
            ¿Por qué este pueblo? ¿Qué te preocupa que se pierda?
          </label>
          <textarea
            id="mensaje"
            name="mensaje"
            rows="5"
            required
            class="w-full px-4 py-3 border border-opita-hueso rounded bg-opita-arena text-opita-cafe focus:outline-none focus:border-opita-tierra resize-y"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full md:w-auto bg-opita-tierra text-opita-arena px-8 py-4 rounded-lg text-lg font-serif hover:bg-opita-verriondo transition-colors"
        >
          Enviar por correo
        </button>

        <p class="text-xs text-opita-cafe/60">
          Al enviar se abrirá tu cliente de correo con los datos prellenados.
          Destino: <code class="bg-opita-arena px-1 rounded">{REPLICA_EMAIL}</code>
        </p>
      </form>

      <p class="text-center text-sm text-opita-cafe/70 mt-6">
        ¿Prefieres chat? <a href={WHATSAPP_URL} class="underline hover:text-opita-tierra">Escríbenos por WhatsApp</a>.
      </p>
    </section>

    <!-- Enlaces al pie -->
    <section class="border-t border-opita-hueso pt-10 text-center text-sm text-opita-cafe/70">
      <p>
        <a href="/" class="underline hover:text-opita-tierra">Volver al inicio</a>
        ·
        <a href="/taller" class="underline hover:text-opita-tierra">El taller académico</a>
        ·
        <a href={WHATSAPP_URL} class="underline hover:text-opita-tierra">WhatsApp</a>
      </p>
    </section>
  </main>
</Layout>