---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Sociedad Opita — Próximamente">
  <main class="max-w-2xl mx-auto px-6 py-24 text-center">
    <p class="text-sm uppercase tracking-widest text-opita-tierra mb-4">Coming soon</p>
    <h1 class="text-5xl font-serif text-opita-cafe mb-6">
      Esta sección pronto tendrá más contenido
    </h1>
    <p class="text-lg text-opita-cafe/80 leading-relaxed mb-6">
      Estamos construyendo el nuevo Sociedad Opita con cuatro dimensiones para habitar el pueblo de
      Tello. Mientras tanto, vuelve al
      <a href="/" class="underline hover:text-opita-tierra">inicio</a>.
    </p>
  </main>
</Layout>
